{
  "name": "ranta",
  "displayName": "Ranta",
  "description": "Tee / Ranta：extension.json（data / process / lambda / event / widget / component）与 Vue 模板、data 访问之间的跳转。",
  "version": "1.0.1",
  "icon": "images/icon.png",
  "publisher": "9y",
  "author": {
    "name": "九月",
    "url": "https://github.com/zxccvvb"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zxccvvb/Ranta.git"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:vue",
    "onLanguage:json"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ranta.goToWidget",
        "title": "Ranta: Go to Definition"
      }
    ],
    "keybindings": [
      {
        "command": "ranta.goToWidget",
        "key": "alt+f12",
        "when": "editorTextFocus && (editorLangId == vue || editorLangId == json || editorLangId == jsonc)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vsix": "npm version patch --no-git-tag-version --no-git-checks && npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^16.18.0",
    "@types/vscode": "^1.74.0",
    "typescript": "^4.9.0"
  }
}
